build/
build_*/
build-*/
*.log
.DS_Store
models/
logs/
server.log
*.gguf
.env.local
config/policy_store.conf
config/policy_store.conf.bak
blogs/
docs/blog/assets/

# Local third-party source checkouts that are not part of this repo's pinned
# vendor set and should never be committed.
external/mlx/
external/mlx-c/
external/mlx-lm/

# Generated artifacts under tracked vendor/source trees. Keep the actual vendor
# sources/submodules tracked; ignore only local top-level build outputs here.
# Submodule-internal build noise (for example `external/llama.cpp/build`) is
# handled via `.gitmodules` so real source edits still surface in `git status`.
external/*/build/
external/*/.cache/
external/*/dist/
external/*/out/
external/*/bin/
external/*/lib/

# Python test/runtime cache artifacts.
__pycache__/
*.pyc

# Local profiling outputs and backup scratch files.
nsys_reports/
gguf_benchmark_results/
*.old
